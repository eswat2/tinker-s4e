{
  "name": "tinker-s4e",
  "version": "0.0.879",
  "description": "prototype - a demo rendered with Svelte and Tailwind",
  "author": "eswat2",
  "license": "MIT",
  "repository": "eswat2/tinker-s4e",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "bump": "bumpp patch --commit --tag --push --yes",
    "deploy-app": "cd dist; ln -s ../.vercel; vc --prod",
    "release": "pnpm bump && pnpm build && pnpm deploy-app",
    "preinstall": "npx only-allow pnpm",
    "dev": "concurrently \"pnpm:twx --watch\" \"pnpm:start\"",
    "twx": "twx",
    "start": "vite",
    "prebuild": "echo skipping pnpm format",
    "build": "pnpm twx; vite build",
    "serve": "vite preview",
    "test": "echo --skip...",
    "cc": "prettier --check './src/**/*.{css,pcss,js,svelte}'",
    "format": "prettier --write './src/**/*.{css,pcss,js,svelte}'",
    "spell": "cspell './**/*.js'",
    "open": "open https://tinker-s4e.vercel.app"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "autoprefixer": "10.5.0",
    "bumpp": "11.1.0",
    "concurrently": "10.0.3",
    "d3-interpolate": "3.0.1",
    "only-allow": "1.2.2",
    "postcss": "8.5.15",
    "prettier": "3.8.4",
    "prettier-plugin-svelte": "4.1.0",
    "prettier-plugin-tailwindcss": "0.8.0",
    "proto-tailwindcss-clrs": "0.0.503",
    "svelte": "5.56.3",
    "tailwindcss": "4.3.1",
    "vite": "8.0.16",
    "yoctocolors": "2.1.2"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
